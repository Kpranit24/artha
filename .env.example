# =============================================================
# .env.example
# PURPOSE:  All environment variables for the finance dashboard
# USAGE:    Copy this to .env and fill in your values
#           cp .env.example .env
#
# NOTES:
#   - Never commit .env to git (it's in .gitignore)
#   - Every variable is documented below
#   - Variables marked FREE need no payment
#   - Variables marked PAID are optional upgrades
#   - Variables marked REQUIRED will break the app if missing
# =============================================================


# ── APP CONFIG ─────────────────────────────────────────────
# REQUIRED

# Options: development | staging | production
# Controls: logging level, error detail, debug tools
ENVIRONMENT=development

# Your app's public URL
# Local:      http://localhost:3000
# Production: https://arthafinance.in (or your domain)
APP_URL=http://localhost:3000

# Backend API URL
# Local:      http://localhost:8000
# Production: https://api.arthafinance.in
API_URL=http://localhost:8000

# Same as API_URL but used by Next.js frontend
# Must start with NEXT_PUBLIC_ to be accessible in browser
NEXT_PUBLIC_API_URL=http://localhost:8000


# ── DATABASE ───────────────────────────────────────────────
# REQUIRED | FREE tier: Supabase 500MB

# Get from: https://supabase.com → New Project → Settings → Database
# Free tier: 500MB storage, 50K monthly active users
# Paid upgrade: $25/mo for 8GB storage
#
# Format: postgresql://user:password@host:5432/database
#
# Providers (only this URL changes when migrating):
#   Supabase:   postgresql://postgres:[pass]@db.[ref].supabase.co:5432/postgres
#   Railway:    postgresql://postgres:[pass]@[host].railway.app:5432/railway
#   AWS RDS:    postgresql://[user]:[pass]@[host].rds.amazonaws.com:5432/artha
#   Neon:       postgresql://[user]:[pass]@[host].neon.tech:5432/artha
#   Local:      postgresql://postgres:password@localhost:5432/artha
DATABASE_URL=postgresql://postgres:password@localhost:5432/artha

# Supabase-specific (needed for auth features)
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key


# ── CACHE ──────────────────────────────────────────────────
# REQUIRED | FREE tier: Upstash 10K commands/day

# Get from: https://upstash.com → Create Database → .env tab
# Free tier: 10,000 commands/day (~500 active users)
# Paid upgrade: Pay-as-you-go ~$10/mo at 1K users
#
# Providers (only this URL changes when migrating):
#   Upstash:        rediss://default:[pass]@[host].upstash.io:6379
#   Railway Redis:  redis://default:[pass]@[host].railway.app:6379
#   AWS ElastiCache: redis://[host].cache.amazonaws.com:6379
#   Local:          redis://localhost:6379
REDIS_URL=redis://localhost:6379


# ── AI — GROQ (PRIMARY, FREE) ─────────────────────────────
# Get free key: https://console.groq.com → API Keys → Create
# Free tier: 14,400 requests/day, 6,000 tokens/min
# REQUIRED for AI insights (or set ENABLE_AI_INSIGHTS=false)
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── AI — CLAUDE (FALLBACK, OPTIONAL) ──────────────────────
# Add later when needed: https://console.anthropic.com
# Only used if Groq fails or is rate limited
# Cost: ~$0.003 per insight
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6


# ── DATA SOURCES — CRYPTO ──────────────────────────────────
# FREE tier sufficient for development and early production

# CoinGecko Public API
# FREE tier: 30 req/min, no key needed
# Get Pro key: https://coingecko.com/en/api/pricing ($129/mo)
# Leave empty to use free tier (recommended to start)
COINGECKO_API_KEY=

# Set to true when you have a paid CoinGecko key
# Unlocks: 500 req/min, historical data, faster refresh
USE_COINGECKO_PRO=false


# ── DATA SOURCES — US STOCKS ───────────────────────────────

# Yahoo Finance (unofficial, free, no key needed)
# RISK: Unofficial API, may break without notice
# FALLBACK: Alpha Vantage free tier (set below)
# Leave this — it's handled automatically in data/sources.py
USE_YAHOO_FINANCE=true

# Alpha Vantage (free fallback for US stocks)
# Get free key: https://alphavantage.co/support/#api-key
# FREE tier: 5 req/min, 500 req/day
# Paid: $50/mo for 75 req/min
ALPHA_VANTAGE_KEY=your-free-key-here

# Polygon.io (PAID — best US stock data)
# Only set if you need institutional-grade US data
# Cost: $199/mo for real-time
# Leave empty to use free sources (Yahoo + Alpha Vantage)
POLYGON_API_KEY=

# Set to true only when POLYGON_API_KEY is set
USE_POLYGON=false


# ── DATA SOURCES — INDIA STOCKS ────────────────────────────

# yfinance (Python library, free, handles NSE/BSE)
# No key needed — handled in backend/data/india.py
# Limitation: ~1 minute delay on some feeds
USE_YFINANCE=true

# Twelve Data (PAID — best NSE/BSE real-time data)
# Cost: $39/mo for real-time Indian market data
# Get key: https://twelvedata.com
# Leave empty to use yfinance (free, slight delay)
TWELVE_DATA_KEY=

# Set to true only when TWELVE_DATA_KEY is set
USE_TWELVE_DATA=false


# ── DATA SOURCES — NEWS ────────────────────────────────────

# NewsAPI (free tier: 100 req/day, no API key for dev)
# Get key: https://newsapi.org/register
# FREE tier: 100 req/day, developer use only
# Paid: $449/mo for production use
# Alternative: RSS feeds (always free, set below)
NEWSAPI_KEY=your-newsapi-key

# RSS feeds used as free fallback for news
# Comma-separated list
# These are always free, no key needed
RSS_FEEDS=https://feeds.finance.yahoo.com/rss/2.0/headline,https://economictimes.indiatimes.com/markets/rssfeeds/1977021501.cms


# ── AUTH ───────────────────────────────────────────────────
# REQUIRED

# JWT secret for signing tokens
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# IMPORTANT: Change this in production, never use the default
JWT_SECRET=change-this-to-a-random-64-char-string-in-production

# Token expiry
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30


# ── NOTIFICATIONS ──────────────────────────────────────────
# OPTIONAL but strongly recommended for monitoring

# Telegram Bot (recommended — free, works great in India)
# Setup:
#   1. Message @BotFather on Telegram
#   2. Create new bot → get token
#   3. Message your bot → get chat ID from:
#      https://api.telegram.org/bot[TOKEN]/getUpdates
# Leave empty to disable Telegram alerts
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Email alerts (optional fallback)
# Uses Gmail SMTP — free with Google account
# Setup: Gmail → Settings → Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL=your-email@gmail.com


# ── RATE LIMITING ──────────────────────────────────────────

# Requests per minute by user tier
# These match Perplexity Finance's tier structure
RATE_LIMIT_FREE=10
RATE_LIMIT_PRO=100
RATE_LIMIT_VIP=1000


# ── CACHE TTL (seconds) ────────────────────────────────────
# Controls how long data lives in Redis
# Lower = fresher data but more API calls (costs more)
# Higher = stale data but fewer API calls (costs less)

# L1 — Live prices (matches Perplexity VIP refresh rate)
CACHE_TTL_PRICES=15

# L2 — Computed metrics (sector momentum, indices)
CACHE_TTL_METRICS=300

# L3 — Fundamentals (P/E, revenue, ratios)
CACHE_TTL_FUNDAMENTALS=3600

# L4 — Historical charts
CACHE_TTL_HISTORICAL=86400

# AI insights (expensive to generate — cache aggressively)
# Same ticker rarely needs fresh insight every 15 seconds
CACHE_TTL_INSIGHTS=3600


# ── MONITORING ─────────────────────────────────────────────

# Daily report time (24hr format, IST)
DAILY_REPORT_HOUR=9
DAILY_REPORT_MINUTE=0

# Alert thresholds
ALERT_API_RESPONSE_MS=500      # Alert if API slower than this
ALERT_MEMORY_MB=450            # Alert if memory above this (Railway = 512MB)
ALERT_DB_STORAGE_PCT=80        # Alert if DB above this % of free tier
ALERT_CLAUDE_SPEND_USD=3       # Alert if Claude API costs more than this per day

# Cost agent daily budget (USD)
DAILY_CLAUDE_BUDGET_USD=5


# ── FEATURE FLAGS ──────────────────────────────────────────
# Toggle features without code changes

# Show "not financial advice" disclaimer (always keep true)
SHOW_DISCLAIMER=true

# Enable AI insights (set false to save Claude API costs during dev)
ENABLE_AI_INSIGHTS=true

# Enable portfolio tracker (requires Supabase auth)
ENABLE_PORTFOLIO=true

# Enable price alerts (requires Telegram or email setup)
ENABLE_ALERTS=true

# Demo mode — use static data, no API calls
# Useful for: UI development, testing, demos
DEMO_MODE=false
