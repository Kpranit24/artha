# ==============================================
# .gitignore — never commit these files
# ==============================================

# ── SECRETS (MOST IMPORTANT) ──────────────────
.env
.env.local
.env.production
.env.staging
# Only .env.example is committed (has no real values)

# ── PYTHON ────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/

# ── NODE / NEXT.JS ────────────────────────────
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# ── DATABASE ──────────────────────────────────
*.sql.backup
backup_*.sql
postgres_data/

# ── DOCKER ────────────────────────────────────
# (docker-compose.yml IS committed — it has no secrets)

# ── IDE ───────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── LOGS ──────────────────────────────────────
*.log
logs/

# ── MISC ──────────────────────────────────────
*.tmp
*.temp
